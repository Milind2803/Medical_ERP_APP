# Optional: full service base URLs (bypass /api/* reverse proxy). Example:
# VITE_USER_SERVICE_URL=http://localhost:8081/api/v1
# VITE_PRODUCT_SERVICE_URL=http://localhost:8082/api/v1
# VITE_ORDER_SERVICE_URL=http://localhost:8083/api/v1

# Dev server only: host for Vite proxy (defaults to 127.0.0.1). Example for remote APIs:
# VITE_PROXY_API_HOST=13.239.35.112
